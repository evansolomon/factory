{
  "name": "@evansolomon/factory",
  "version": "0.1.2",
  "description": "A self-improving coding loop: queue tasks in a git worktree and have a cross-model agent ensemble plan, implement, review, verify, and commit each one.",
  "license": "MIT",
  "author": "Evan Solomon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evansolomon/factory.git"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "factory": "src/cli.ts"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:local": "bash scripts/build-local.sh",
    "build:release": "bash .github/scripts/build-binaries.sh",
    "test": "biome check . && tsc --noEmit && bun test",
    "fix": "biome check --write ."
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
